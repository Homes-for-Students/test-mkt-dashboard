# =========================================================================
# PBSA Marketing Dashboard Environment Configurations
# Copy this file to a new file named '.env' in the same folder and fill in the keys.
# =========================================================================

# Database Connection (MySQL / Drizzle)
# Leave blank to fallback to in-memory SQLite / mock caching
DATABASE_URL=mysql://user:password@localhost:3306/marketing_dashboard

# Google Sheets Configuration (for Executive Sales & Occupancy Metrics)
# 1. Open your Google Sheet in a browser.
# 2. Copy the long ID from the URL (between /d/ and /edit).
# 3. Ensure the spreadsheet sharing permissions are set to: "Anyone with the link can view".
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Supermetrics API Key
# Token key to retrieve Meta Ads, Google Ads, and GA4 website traffic metrics
SUPERMETRICS_API_KEY=your_supermetrics_api_token_here

# Google Maps API Integration (for Google Places Ratings/Reviews)
# Place ID for your Google Maps property listing
GOOGLE_MAPS_PLACE_ID=your_google_maps_place_id_here
# Standard Google Developer Credentials (needs Places API enabled)
GOOGLE_MAPS_API_KEY=your_google_cloud_api_key_here

# StudentCrowd API Integration
# Get this key from your StudentCrowd account manager or support@studentcrowd.com
STUDENT_CROWD_API_KEY=your_student_crowd_api_key_here

# DfT Bus Open Data Service (BODS) API
# Register and get your key from https://data.bus-data.dft.gov.uk/
BODS_API_KEY=your_bods_api_key_here
# =========================================================================
# Google Cloud APIs & Ads Configuration (For GA4, Google Ads, and Maps)
# =========================================================================

# Google Sheets Configuration
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Ads API Credentials
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
META_ACCESS_TOKEN=

# Resend Email Configuration (For Passcode Auth Emails)
# Register at https://resend.com/
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=no-reply@yourverifieddomain.com
RESEND_TEMPLATE_ID=

